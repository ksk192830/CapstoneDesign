{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESP32-P4 Machine Protocol v1 WebSocket Message",
  "type": "object",
  "required": ["version", "type", "seq", "payload"],
  "properties": {
    "version": {
      "const": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "hello",
        "hello_ack",
        "control",
        "stop",
        "emergency_stop",
        "set_mode",
        "status",
        "ack",
        "error",
        "ping",
        "pong"
      ]
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp_ms": {
      "type": "number"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
