{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ESP32-P4 Machine Protocol Message",
  "type": "object",
  "required": ["type", "seq"],
  "properties": {
    "type": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "number"
    }
  },
  "additionalProperties": true
}

